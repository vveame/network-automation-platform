# EdgeRouter-VPNGateway underlay metadata.
# Copy locally to:
#   frr/wireguard/edge-underlay.env
#
# Do NOT commit the real .env file.

# direct = EdgeRouter has eth3 connected to GNS3 NAT node.
# devops = old fallback where DevOps provides NAT underlay.
UNDERLAY_MODE="direct"

# AWS tunnel gateway PUBLIC IP, not the private monitoring EC2 IP.
AWS_TUNNEL_PUBLIC_IP="CHANGE_ME"

# EdgeRouter WAN interface connected to GNS3 NAT node.
WAN_IF="eth3"

# Used only if UNDERLAY_MODE="devops".
DEVOPS_UNDERLAY_GW="10.200.0.10"
EDGE_OOB_IF="eth4"

# AWS VPC CIDR routed through WireGuard.
AWS_VPC_CIDR="10.50.0.0/16"
