# EdgeRouter-VPNGateway WireGuard underlay metadata.
# Copy this file locally to:
#   frr/wireguard/edge-underlay.env
#
# Do NOT commit the real .env file.

# Public IP of the AWS EC2 tunnel gateway.
AWS_TUNNEL_PUBLIC_IP="CHANGE_ME"

# DevOps OOB IP used only as NAT/internet underlay.
# DevOps does NOT terminate WireGuard.
DEVOPS_UNDERLAY_GW="10.200.0.10"

# EdgeRouter OOB interface toward DevOps.
EDGE_OOB_IF="eth4"

# AWS VPC CIDR routed through WireGuard.
AWS_VPC_CIDR="10.50.0.0/16"
