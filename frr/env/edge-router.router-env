ROUTER_NAME=edge-router
ROUTER_HOSTNAME=EdgeRouter-VPNGateway
ROUTER_ROLE=edge

# EdgeRouter-VPNGateway direct underlay:
# eth3 is connected to GNS3 NAT and receives internet via DHCP.
# eth4 remains OOB/management toward DevOps.
ENABLE_NAT=true
UNDERLAY_MODE=direct
WAN_IF=eth3
EXTERNAL_IFACE=eth3
ENABLE_DHCP=true
