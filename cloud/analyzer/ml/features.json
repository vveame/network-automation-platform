{
  "description": "Prometheus query_range feature definitions for ML-based anomaly detection. The feature scope mirrors the existing S3 metrics snapshot export while using historical Prometheus windows instead of instant snapshots.",
  "source_alignment": {
    "instant_snapshot_script": "monitoring/scripts/export-prometheus-snapshot.sh",
    "rule_based_parser": "cloud/analyzer/parse_prometheus_metrics.py",
    "ml_collection_mode": "Prometheus /api/v1/query_range"
  },
  "prometheus_job_scope": {
    "blackbox": "blackbox-http|blackbox-tcp|blackbox-dns",
    "node_exporter": "node-exporter",
    "snmp": "snmp-network-devices"
  },
  "features": [
    {
      "name": "all_targets_down",
      "group": "target_health",
      "query": "sum(1 - up)"
    },
    {
      "name": "all_targets_up_ratio",
      "group": "target_health",
      "query": "avg(up)"
    },

    {
      "name": "service_probe_success_ratio",
      "group": "blackbox",
      "query": "avg(probe_success{job=~\"blackbox-http|blackbox-tcp|blackbox-dns\"})"
    },
    {
      "name": "service_probe_failures",
      "group": "blackbox",
      "query": "sum(1 - probe_success{job=~\"blackbox-http|blackbox-tcp|blackbox-dns\"})"
    },
    {
      "name": "web_http_probe_failed",
      "group": "blackbox",
      "query": "sum(1 - probe_success{job=\"blackbox-http\"})"
    },
    {
      "name": "dns_probe_failed",
      "group": "blackbox",
      "query": "sum(1 - probe_success{job=\"blackbox-dns\"})"
    },
    {
      "name": "tcp_probe_failures",
      "group": "blackbox",
      "query": "sum(1 - probe_success{job=\"blackbox-tcp\"})"
    },
    {
      "name": "avg_probe_duration_seconds",
      "group": "blackbox",
      "query": "avg(probe_duration_seconds{job=~\"blackbox-http|blackbox-tcp|blackbox-dns\"})"
    },
    {
      "name": "max_probe_duration_seconds",
      "group": "blackbox",
      "query": "max(probe_duration_seconds{job=~\"blackbox-http|blackbox-tcp|blackbox-dns\"})"
    },
    {
      "name": "avg_dns_lookup_time_seconds",
      "group": "blackbox",
      "query": "avg(probe_dns_lookup_time_seconds{job=~\"blackbox-http|blackbox-dns\"})"
    },
    {
      "name": "max_dns_lookup_time_seconds",
      "group": "blackbox",
      "query": "max(probe_dns_lookup_time_seconds{job=~\"blackbox-http|blackbox-dns\"})"
    },
    {
      "name": "http_status_not_200_count",
      "group": "blackbox",
      "query": "count(probe_http_status_code{job=\"blackbox-http\"} != 200)"
    },

    {
      "name": "avg_host_cpu_usage_percent",
      "group": "node_exporter",
      "query": "avg(100 - (avg by (instance, node_name, role) (rate(node_cpu_seconds_total{job=\"node-exporter\",mode=\"idle\"}[5m])) * 100))"
    },
    {
      "name": "max_host_cpu_usage_percent",
      "group": "node_exporter",
      "query": "max(100 - (avg by (instance, node_name, role) (rate(node_cpu_seconds_total{job=\"node-exporter\",mode=\"idle\"}[5m])) * 100))"
    },
    {
      "name": "avg_node_load1",
      "group": "node_exporter",
      "query": "avg(node_load1{job=\"node-exporter\"})"
    },
    {
      "name": "max_node_load1",
      "group": "node_exporter",
      "query": "max(node_load1{job=\"node-exporter\"})"
    },
    {
      "name": "avg_node_load5",
      "group": "node_exporter",
      "query": "avg(node_load5{job=\"node-exporter\"})"
    },
    {
      "name": "max_node_load5",
      "group": "node_exporter",
      "query": "max(node_load5{job=\"node-exporter\"})"
    },
    {
      "name": "avg_node_load15",
      "group": "node_exporter",
      "query": "avg(node_load15{job=\"node-exporter\"})"
    },
    {
      "name": "max_node_load15",
      "group": "node_exporter",
      "query": "max(node_load15{job=\"node-exporter\"})"
    },
    {
      "name": "avg_host_memory_used_percent",
      "group": "node_exporter",
      "query": "avg(100 * (1 - (node_memory_MemAvailable_bytes{job=\"node-exporter\"} / node_memory_MemTotal_bytes{job=\"node-exporter\"})))"
    },
    {
      "name": "max_host_memory_used_percent",
      "group": "node_exporter",
      "query": "max(100 * (1 - (node_memory_MemAvailable_bytes{job=\"node-exporter\"} / node_memory_MemTotal_bytes{job=\"node-exporter\"})))"
    },
    {
      "name": "avg_root_disk_used_percent",
      "group": "node_exporter",
      "query": "avg(100 * (1 - (node_filesystem_avail_bytes{job=\"node-exporter\", mountpoint=\"/\", fstype!~\"tmpfs|overlay|squashfs|devtmpfs\"} / node_filesystem_size_bytes{job=\"node-exporter\", mountpoint=\"/\", fstype!~\"tmpfs|overlay|squashfs|devtmpfs\"})))"
    },
    {
      "name": "max_root_disk_used_percent",
      "group": "node_exporter",
      "query": "max(100 * (1 - (node_filesystem_avail_bytes{job=\"node-exporter\", mountpoint=\"/\", fstype!~\"tmpfs|overlay|squashfs|devtmpfs\"} / node_filesystem_size_bytes{job=\"node-exporter\", mountpoint=\"/\", fstype!~\"tmpfs|overlay|squashfs|devtmpfs\"})))"
    },
    {
      "name": "readonly_filesystem_count",
      "group": "node_exporter",
      "query": "sum(node_filesystem_readonly{job=\"node-exporter\", mountpoint=\"/\"})"
    },
    {
      "name": "recent_host_reboot_count",
      "group": "node_exporter",
      "query": "count((time() - node_boot_time_seconds{job=\"node-exporter\"}) < 600)"
    },

    {
      "name": "snmp_devices_down",
      "group": "snmp",
      "query": "sum(1 - up{job=\"snmp-network-devices\"})"
    },
    {
      "name": "snmp_up_ratio",
      "group": "snmp",
      "query": "avg(up{job=\"snmp-network-devices\"})"
    },
    {
      "name": "recent_network_device_reboot_count",
      "group": "snmp",
      "query": "count((sysUpTime{job=\"snmp-network-devices\"} / 100) < 600)"
    },

    {
      "name": "admin_up_interfaces_down",
      "group": "snmp_interface_state",
      "query": "count((ifOperStatus{job=\"snmp-network-devices\", ifDescr!~\"lo|ovs-system|vrrp.*\"} != 1) and on(instance, ifIndex) (ifAdminStatus{job=\"snmp-network-devices\", ifDescr!~\"lo|ovs-system|vrrp.*\"} == 1))"
    },
    {
      "name": "oper_down_interfaces",
      "group": "snmp_interface_state",
      "query": "count(ifOperStatus{job=\"snmp-network-devices\", ifDescr!~\"lo|ovs-system|vrrp.*\"} != 1)"
    },
    {
      "name": "admin_down_interfaces",
      "group": "snmp_interface_state",
      "query": "count(ifAdminStatus{job=\"snmp-network-devices\", ifDescr!~\"lo|ovs-system|vrrp.*\"} != 1)"
    },
    {
      "name": "recent_interface_change_count",
      "group": "snmp_interface_state",
      "query": "count(changes(ifOperStatus{job=\"snmp-network-devices\", ifDescr!~\"lo|ovs-system|vrrp.*\"}[10m]) > 0)"
    },

    {
      "name": "interface_in_bps",
      "group": "snmp_traffic",
      "query": "sum(8 * rate(ifHCInOctets{job=\"snmp-network-devices\", ifDescr!~\"lo|ovs-system|vrrp.*\"}[5m]))"
    },
    {
      "name": "interface_out_bps",
      "group": "snmp_traffic",
      "query": "sum(8 * rate(ifHCOutOctets{job=\"snmp-network-devices\", ifDescr!~\"lo|ovs-system|vrrp.*\"}[5m]))"
    },
    {
      "name": "max_interface_in_bps",
      "group": "snmp_traffic",
      "query": "max(8 * rate(ifHCInOctets{job=\"snmp-network-devices\", ifDescr!~\"lo|ovs-system|vrrp.*\"}[5m]))"
    },
    {
      "name": "max_interface_out_bps",
      "group": "snmp_traffic",
      "query": "max(8 * rate(ifHCOutOctets{job=\"snmp-network-devices\", ifDescr!~\"lo|ovs-system|vrrp.*\"}[5m]))"
    },
    {
      "name": "traffic_total_bps",
      "group": "snmp_traffic",
      "query": "sum(8 * rate(ifHCInOctets{job=\"snmp-network-devices\", ifDescr!~\"lo|ovs-system|vrrp.*\"}[5m])) + sum(8 * rate(ifHCOutOctets{job=\"snmp-network-devices\", ifDescr!~\"lo|ovs-system|vrrp.*\"}[5m]))"
    },

    {
      "name": "interface_error_rate",
      "group": "snmp_errors_discards",
      "query": "sum(rate(ifInErrors{job=\"snmp-network-devices\", ifDescr!~\"lo|ovs-system|vrrp.*\"}[5m]) + rate(ifOutErrors{job=\"snmp-network-devices\", ifDescr!~\"lo|ovs-system|vrrp.*\"}[5m]))"
    },
    {
      "name": "interfaces_with_error_rate",
      "group": "snmp_errors_discards",
      "query": "count((rate(ifInErrors{job=\"snmp-network-devices\", ifDescr!~\"lo|ovs-system|vrrp.*\"}[5m]) + rate(ifOutErrors{job=\"snmp-network-devices\", ifDescr!~\"lo|ovs-system|vrrp.*\"}[5m])) > 0)"
    },
    {
      "name": "interface_discard_rate",
      "group": "snmp_errors_discards",
      "query": "sum(rate(ifInDiscards{job=\"snmp-network-devices\", ifDescr!~\"lo|ovs-system|vrrp.*\"}[5m]) + rate(ifOutDiscards{job=\"snmp-network-devices\", ifDescr!~\"lo|ovs-system|vrrp.*\"}[5m]))"
    },
    {
      "name": "interfaces_with_discard_rate",
      "group": "snmp_errors_discards",
      "query": "count((rate(ifInDiscards{job=\"snmp-network-devices\", ifDescr!~\"lo|ovs-system|vrrp.*\"}[5m]) + rate(ifOutDiscards{job=\"snmp-network-devices\", ifDescr!~\"lo|ovs-system|vrrp.*\"}[5m])) > 0)"
    },

    {
      "name": "avg_interface_mtu",
      "group": "snmp_capacity",
      "query": "avg(ifMtu{job=\"snmp-network-devices\", ifDescr!~\"lo|ovs-system|vrrp.*\"})"
    },
    {
      "name": "max_interface_high_speed_mbps",
      "group": "snmp_capacity",
      "query": "max(ifHighSpeed{job=\"snmp-network-devices\", ifDescr!~\"lo|ovs-system|vrrp.*\"})"
    },
    {
      "name": "estimated_max_interface_utilization_percent",
      "group": "snmp_capacity",
      "query": "max(((8 * rate(ifHCInOctets{job=\"snmp-network-devices\", ifDescr!~\"lo|ovs-system|vrrp.*\"}[5m])) + (8 * rate(ifHCOutOctets{job=\"snmp-network-devices\", ifDescr!~\"lo|ovs-system|vrrp.*\"}[5m]))) / clamp_min(ifHighSpeed{job=\"snmp-network-devices\", ifDescr!~\"lo|ovs-system|vrrp.*\"} * 1000000, 1) * 100)"
    }
  ]
}