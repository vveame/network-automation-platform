# AWS EC2 tunnel gateway: /etc/wireguard/wg0.conf
# Do not commit real private keys.

[Interface]
Address = 10.255.0.1/30
ListenPort = 51820
PrivateKey = CLOUD_PRIVATE_KEY

PostUp = sysctl -w net.ipv4.ip_forward=1
PostUp = iptables -C INPUT -p udp --dport 51820 -j ACCEPT 2>/dev/null || iptables -I INPUT 5 -p udp --dport 51820 -j ACCEPT
PostUp = iptables -C FORWARD -m conntrack --ctstate RELATED,ESTABLISHED -j ACCEPT 2>/dev/null || iptables -I FORWARD 1 -m conntrack --ctstate RELATED,ESTABLISHED -j ACCEPT
PostUp = iptables -C FORWARD -i wg0 -d 10.50.0.0/16 -j ACCEPT 2>/dev/null || iptables -I FORWARD 1 -i wg0 -d 10.50.0.0/16 -j ACCEPT
PostUp = iptables -C FORWARD -o wg0 -s 10.50.0.0/16 -j ACCEPT 2>/dev/null || iptables -I FORWARD 1 -o wg0 -s 10.50.0.0/16 -j ACCEPT

PostDown = iptables -D INPUT -p udp --dport 51820 -j ACCEPT 2>/dev/null || true
PostDown = iptables -D FORWARD -m conntrack --ctstate RELATED,ESTABLISHED -j ACCEPT 2>/dev/null || true
PostDown = iptables -D FORWARD -i wg0 -d 10.50.0.0/16 -j ACCEPT 2>/dev/null || true
PostDown = iptables -D FORWARD -o wg0 -s 10.50.0.0/16 -j ACCEPT 2>/dev/null || true

[Peer]
# Local tunnel endpoint that represents the EdgeRouter-VPNGateway path.
PublicKey = LOCAL_PUBLIC_KEY

# Local tunnel IP + local lab/OOB ranges reachable through the edge path.
AllowedIPs = 10.255.0.2/32, 10.200.0.0/24, 172.16.0.0/16
PersistentKeepalive = 25
