  "panels": [
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "Estimated risk score calculated from the same metric families used later by the analyzer: failed probes, targets down, SNMP failures, interface anomalies, errors and resource saturation.",
      "fieldConfig": {
        "defaults": {
          "max": 100,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 30
              },
              {
                "color": "red",
                "value": 70
              }
            ]
          },
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 5,
        "w": 8,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "clamp_max((count(up == 0) * 10) + (count(probe_success{job=~\"blackbox-http|blackbox-tcp|blackbox-dns\"} == 0) * 20) + (count(probe_duration_seconds{job=~\"blackbox-http|blackbox-tcp|blackbox-dns\"} > 1) * 10) + (count(up{job=\"snmp-network-devices\"} == 0) * 20) + (count((ifOperStatus{job=\"snmp-network-devices\", ifDescr!~\"lo|ovs-system|vrrp.*\"} != 1) and on(instance, ifIndex) (ifAdminStatus{job=\"snmp-network-devices\", ifDescr!~\"lo|ovs-system|vrrp.*\"} == 1)) * 10) + (sum(rate(ifInErrors{job=\"snmp-network-devices\", ifDescr!~\"lo|ovs-system|vrrp.*\"}[5m]) + rate(ifOutErrors{job=\"snmp-network-devices\", ifDescr!~\"lo|ovs-system|vrrp.*\"}[5m])) * 10) + (count((100 * (1 - (node_memory_MemAvailable_bytes{job=\"node-exporter\"} / node_memory_MemTotal_bytes{job=\"node-exporter\"}))) > 85) * 10) + (count((100 * (1 - (node_filesystem_avail_bytes{job=\"node-exporter\", mountpoint=\"/\", fstype!~\"tmpfs|overlay|squashfs\"} / node_filesystem_size_bytes{job=\"node-exporter\", mountpoint=\"/\", fstype!~\"tmpfs|overlay|squashfs\"}))) > 85) * 10), 100)",
          "legendFormat": "risk score",
          "refId": "A"
        }
      ],
      "title": "Estimated Anomaly Risk Score",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
