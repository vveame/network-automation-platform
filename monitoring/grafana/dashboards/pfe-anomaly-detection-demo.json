      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "clamp_max(((count(probe_success{job=~\"blackbox-http|blackbox-tcp|blackbox-dns\"} == 0) or vector(0)) * 20) + ((count(probe_duration_seconds{job=~\"blackbox-http|blackbox-tcp|blackbox-dns\"} > 1) or vector(0)) * 10) + ((count(up{job=\"snmp-network-devices\"} == 0) or vector(0)) * 20) + ((count((ifOperStatus{job=\"snmp-network-devices\", ifDescr!~\"lo|ovs-system|vrrp.*\"} != 1) and on(instance, ifIndex) (ifAdminStatus{job=\"snmp-network-devices\", ifDescr!~\"lo|ovs-system|vrrp.*\"} == 1)) or vector(0)) * 15) + ((sum(rate(ifInErrors{job=\"snmp-network-devices\", ifDescr!~\"lo|ovs-system|vrrp.*\"}[5m]) + rate(ifOutErrors{job=\"snmp-network-devices\", ifDescr!~\"lo|ovs-system|vrrp.*\"}[5m])) or vector(0)) * 10) + ((sum(rate(ifInDiscards{job=\"snmp-network-devices\", ifDescr!~\"lo|ovs-system|vrrp.*\"}[5m]) + rate(ifOutDiscards{job=\"snmp-network-devices\", ifDescr!~\"lo|ovs-system|vrrp.*\"}[5m])) or vector(0)) * 10) + (((max(100 * (1 - avg by(instance) (rate(node_cpu_seconds_total{job=\"node-exporter\", mode=\"idle\"}[5m])))) or vector(0)) > bool 85) * 10) + (((max(100 * (1 - (node_memory_MemAvailable_bytes{job=\"node-exporter\"} / node_memory_MemTotal_bytes{job=\"node-exporter\"}))) or vector(0)) > bool 85) * 10) + (((max(100 * (1 - (node_filesystem_avail_bytes{job=\"node-exporter\", mountpoint=\"/\", fstype!~\"tmpfs|overlay|squashfs\"} / node_filesystem_size_bytes{job=\"node-exporter\", mountpoint=\"/\", fstype!~\"tmpfs|overlay|squashfs\"}))) or vector(0)) > bool 85) * 10), 100)",
          "legendFormat": "Estimated Anomaly Risk",
          "range": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 0,
