        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "count((ifOperStatus{job=\"snmp-network-devices\", ifDescr!~\"lo|ovs-system|vrrp.*\"} != 1) and on(instance, ifIndex) (ifAdminStatus{job=\"snmp-network-devices\", ifDescr!~\"lo|ovs-system|vrrp.*\"} == 1))",
          "legendFormat": "interfaces down",
          "refId": "A"
        }
      ],
      "title": "Admin-Up Interfaces Down",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "Total interface error rate from SNMP counters.",
      "fieldConfig": {
        "defaults": {
          "decimals": 3,
          "thresholds": {
            "mode": "absolute",
