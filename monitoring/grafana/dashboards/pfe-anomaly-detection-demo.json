          "expr": "sum(rate(ifInErrors{job=\"snmp-network-devices\", ifDescr!~\"lo|ovs-system|vrrp.*\"}[5m]) + rate(ifOutErrors{job=\"snmp-network-devices\", ifDescr!~\"lo|ovs-system|vrrp.*\"}[5m]))",
