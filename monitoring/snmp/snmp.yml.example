# Example SNMP Exporter configuration for the PFE lab.
# Safe to commit because it contains placeholder values only.
#
# Real deployed file on DevOps VM:
# /etc/prometheus/snmp.yml
#
# IMPORTANT:
# The installed prometheus-snmp-exporter package does not support
# --config.expand-environment-variables.
#
# The real /etc/prometheus/snmp.yml is generated locally by:
# monitoring/scripts/build-local-snmp-exporter-config.sh
#
# That script extracts the full generated SNMP Exporter module config from
# the Debian package and injects the local SNMPv3 auth block from:
# monitoring/snmp/snmp-auth.local.yml
#
# Do not copy this example directly over /etc/prometheus/snmp.yml.

auths:
  pfe_snmpv3_authpriv:
    version: 3
    security_level: authPriv
    username: pfe_snmp_ro
    password: CHANGE_ME_AUTH_PASSWORD_16PLUS
    auth_protocol: SHA
    priv_protocol: AES
    priv_password: CHANGE_ME_PRIV_PASSWORD_16PLUS

modules:
  if_mib:
    # The real generated config contains a full metrics: mapping block.
    # This example is intentionally minimal and is only for documentation.
    walk:
      - 1.3.6.1.2.1.1
      - 1.3.6.1.2.1.2
      - 1.3.6.1.2.1.31.1.1
