# Example only. Do not commit the real .env file.
#
# Real local file expected on the GNS3 host:
# ovs/snmp/env/ovs-switches.snmp.env
#
# This file is copied by the persistent bootstrap into each OVS node:
# /etc/local/snmp/snmp.env
#
# Shared lab SNMPv3 profile for all OVS switches.

SNMP_ENABLE=true
SNMP_AGENT_PORT=1161
SNMP_V3_USERNAME=pfe_snmp_ro
SNMP_V3_AUTH_PASSWORD=CHANGE_ME_AUTH_PASSWORD_16PLUS
SNMP_V3_PRIV_PASSWORD=CHANGE_ME_PRIV_PASSWORD_16PLUS
